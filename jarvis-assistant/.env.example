# JARVIS Assistant — Environment Variables
# Copy this file to .env and fill in your values

# ── REQUIRED ──────────────────────────────────────────────────
# Anthropic API key (for JARVIS AI responses)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ── STAGE 3: Realistic Voice (ElevenLabs) ────────────────────
# Without this, JARVIS uses the browser's built-in Web Speech API (less realistic)
# Get a key at: https://elevenlabs.io  (free tier available)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Voice ID — default is "Daniel" (British male, perfect for JARVIS)
# Other good options:
#   Adam  (deep, authoritative):  pNInz6obpgDQGcFmaJgB
#   Josh  (deep, warm):           TxGEqnHWrfWFTfGW9XjX
#   Daniel (British male):        onwK4e9ZLuTAKqWW03F9  ← DEFAULT
# Browse all voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── STAGE 2: Speech-to-Text ───────────────────────────────────
# Web Speech API is used by default (built into Chromium, no key needed)
# If you want offline/higher-accuracy STT, Whisper can be wired in Stage 2+

# ── Server config (only change if port 3001 is taken) ────────
BACKEND_PORT=3001
