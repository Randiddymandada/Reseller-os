# JARVIS Assistant — Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Your Anthropic API key
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# OPTIONAL: Stage 2+ — Speech to Text
# OPENAI_API_KEY=your_openai_key_here   # For Whisper STT
# WHISPER_MODEL=base                     # tiny | base | small | medium | large

# OPTIONAL: Stage 3+ — Realistic Voice Output
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here

# Server config (do not change unless you have a port conflict)
BACKEND_PORT=3001
